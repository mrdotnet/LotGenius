# Explorer data source. Default is the bundled synthetic fixture (no Azure needed).
#   VITE_EXPLORER_SOURCE=fixture   -> bundled deterministic corpus (default)
#   VITE_EXPLORER_SOURCE=live      -> read-only aggregate endpoint over curated_lots
VITE_EXPLORER_SOURCE=fixture

# Only read when VITE_EXPLORER_SOURCE=live. The future read-only aggregate export
# endpoint (see explorer-web/README.md "Live wiring"). Not wired in the PoC.
# VITE_EXPLORER_API=https://<aggregate-export-endpoint>
