.DS_Store

# Local agentic-RAG testbed — Kadima Background IP runtime + dummy data.
# NOT a Deliverable (PRD §9): the runtime implementation must never ship as source
# in this repo. Lives here only for local build/test while access is pending.
local-dev/

# Claude Code local / runtime (per-user, provisioned not committed)
# `.claude/helpers/` is re-installed per clone via the provision-repo-claude skill.
# Tracked: .claude/settings.json, .claude/hooks/. Ignored: the rest below.
.claude/settings.local.json
.claude/config/
.claude/tts-*.txt
.claude/helpers/
.claude/scheduled_tasks.lock
.claude/worktrees/

# Rust build output (all crates) + Python venvs + ephemeral terraform plan files
**/target/
**/.venv/
*.plan

# Env files (may hold endpoints/keys) — keep only the committed examples.
.env
.env.*
!.env.example

# Terraform (infra/) — caches, state, and filled-in vars are local/secret.
# Tracked by design: *.tf, terraform.tfvars.example, and .terraform.lock.hcl (version pins).
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
crash.log
crash.*.log

# Local swarm / sptflo runtime state (machine-local, not a deliverable)
.spt/
.sptflo/

# CLIENT-CONFIDENTIAL — Steffes Azure security assessment (live-tenant findings:
# resource names, public IPs, privileged principal GUIDs). NEVER commit/push.
Docs/steffes-az-security-assessment.*

# Local sptflo orchestration (dev tooling; not a deliverable)
.mcp.json

# Python build/cache artifacts (must never be tracked)
__pycache__/
*.py[cod]
*.egg-info/
